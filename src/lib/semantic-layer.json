{
  "entities": {
    "users": {
      "id": "users",
      "table": "users",
      "primaryKey": "id",
      "description": "用户信息",
      "type": "dimension",
      "defaultTimeColumn": "users.joined_at"
    },
    "products": {
      "id": "products",
      "table": "products",
      "primaryKey": "id",
      "description": "产品信息",
      "type": "dimension",
      "defaultTimeColumn": "products.created_at"
    },
    "orders": {
      "id": "orders",
      "table": "orders",
      "primaryKey": "id",
      "description": "订单交易信息",
      "type": "fact",
      "defaultTimeColumn": "orders.order_date"
    },
    "returns": {
      "id": "returns",
      "table": "returns",
      "primaryKey": "id",
      "description": "退货信息",
      "type": "fact",
      "defaultTimeColumn": "returns.return_date"
    }


  },
  "metrics": {
    "sales_amount": {
      "id": "sales_amount",
      "name": "销售额",
      "expression": "SUM(orders.total_price)",
      "description": "所有订单的总金额",
      "entityId": "orders",
      "timeColumn": "orders.order_date",
      "certified": true,
      "businessDefinition": "销售额口径为所有订单 total_price 的汇总，按订单日期归属到统计周期。",
      "allowDetailDrilldown": false
    },
    "order_count": {
      "id": "order_count",
      "name": "订单量",
      "expression": "COUNT(orders.id)",
      "description": "总订单数",
      "entityId": "orders",
      "timeColumn": "orders.order_date",
      "certified": true,
      "businessDefinition": "订单量口径为订单表中的订单记录数，按订单日期归属到统计周期。",
      "allowDetailDrilldown": false
    },
    "user_count": {
      "id": "user_count",
      "name": "用户数",
      "expression": "COUNT(DISTINCT users.id)",
      "description": "注册用户总数",
      "entityId": "users",
      "timeColumn": "users.joined_at",
      "certified": true,
      "businessDefinition": "用户数口径为去重后的注册用户数量，按用户注册时间归属到统计周期。",
      "allowDetailDrilldown": false
    },
    "return_amount": {
      "id": "return_amount",
      "name": "退货金额",
      "expression": "SUM(returns.amount)",
      "description": "总退货金额",
      "entityId": "returns",
      "timeColumn": "returns.return_date",
      "certified": true,
      "businessDefinition": "退货金额口径为退货表 amount 的汇总，按退货发生日期归属到统计周期。",
      "allowDetailDrilldown": false
    },
    "aov": {
      "id": "aov",
      "name": "客单价",
      "expression": "SUM(orders.total_price) / NULLIF(COUNT(orders.id), 0)",
      "description": "平均订单金额",
      "entityId": "orders",
      "timeColumn": "orders.order_date",
      "certified": true,
      "businessDefinition": "客单价口径为销售额除以订单量，用于衡量每笔订单的平均成交金额。",
      "allowDetailDrilldown": false,
      "formula": "{{sales_amount}} / {{order_count}}"
    }


  },
  "dimensions": {
    "user_country": {
      "id": "user_country",
      "name": "国家",
      "column": "users.country",
      "description": "用户所属国家",
      "entityId": "users",
      "certified": true
    },
    "product_category": {
      "id": "product_category",
      "name": "产品类别",
      "column": "products.category",
      "description": "产品所属分类",
      "entityId": "products",
      "certified": true
    },
    "age_group": {
      "id": "age_group",
      "name": "年龄段",
      "column": "CASE WHEN users.age < 18 THEN '未成年' WHEN users.age < 35 THEN '青年' WHEN users.age < 60 THEN '中年' ELSE '老年' END",
      "description": "根据用户年龄划分的年龄段",
      "entityId": "users",
      "certified": true,
      "transform": "CASE WHEN users.age < 18 THEN '未成年' WHEN users.age < 35 THEN '青年' WHEN users.age < 60 THEN '中年' ELSE '老年' END"
    },

    "order_date": {
      "id": "order_date",
      "name": "下单日期",
      "column": "orders.order_date",
      "description": "下单的时间日期",
      "entityId": "orders",
      "certified": true,
      "timeGrain": "day"
    },
    "order_month": {
      "id": "order_month",
      "name": "下单月份",
      "column": "orders.order_date",
      "description": "按下单日期归属到月份，用于月度趋势、同比和环比分析",
      "entityId": "orders",
      "certified": true,
      "transform": "DATE_TRUNC('month', orders.order_date)::date",
      "timeGrain": "month"
    },
    "return_date": {
      "id": "return_date",
      "name": "退货日期",
      "column": "returns.return_date",
      "description": "退货发生日期",
      "entityId": "returns",
      "certified": true,
      "timeGrain": "day"
    },
    "return_month": {
      "id": "return_month",
      "name": "退货月份",
      "column": "returns.return_date",
      "description": "按退货日期归属到月份，用于月度退货趋势分析",
      "entityId": "returns",
      "certified": true,
      "transform": "DATE_TRUNC('month', returns.return_date)::date",
      "timeGrain": "month"
    },
    "username": {
      "id": "username",
      "name": "用户名",
      "column": "users.username",
      "description": "用户名称",
      "entityId": "users",
      "certified": true
    }
  },
  "relationships": [
    {
      "fromEntityId": "users",
      "toEntityId": "orders",
      "joinOn": "users.id = orders.user_id",
      "type": "one_to_many",
      "certified": true
    },
    {
      "fromEntityId": "products",
      "toEntityId": "orders",
      "joinOn": "products.id = orders.product_id",
      "type": "one_to_many",
      "certified": true
    },
    {
      "fromEntityId": "users",
      "toEntityId": "returns",
      "joinOn": "users.id = returns.user_id",
      "type": "one_to_many",
      "certified": true
    }

  ]
}
