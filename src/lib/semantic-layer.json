{
  "entities": {
    "users": {
      "id": "users",
      "table": "users",
      "primaryKey": "id",
      "description": "用户信息",
      "type": "dimension"
    },
    "products": {
      "id": "products",
      "table": "products",
      "primaryKey": "id",
      "description": "产品信息",
      "type": "dimension"
    },
    "orders": {
      "id": "orders",
      "table": "orders",
      "primaryKey": "id",
      "description": "订单交易信息",
      "type": "fact"
    },
    "returns": {
      "id": "returns",
      "table": "returns",
      "primaryKey": "id",
      "description": "退货信息",
      "type": "fact"
    }


  },
  "metrics": {
    "sales_amount": {
      "id": "sales_amount",
      "name": "销售额",
      "expression": "SUM(orders.total_price)",
      "description": "所有订单的总金额",
      "entityId": "orders"
    },
    "order_count": {
      "id": "order_count",
      "name": "订单量",
      "expression": "COUNT(orders.id)",
      "description": "总订单数",
      "entityId": "orders"
    },
    "user_count": {
      "id": "user_count",
      "name": "用户数",
      "expression": "COUNT(DISTINCT users.id)",
      "description": "注册用户总数",
      "entityId": "users"
    },
    "return_amount": {
      "id": "return_amount",
      "name": "退货金额",
      "expression": "SUM(returns.amount)",
      "description": "总退货金额",
      "entityId": "returns"
    }

  },
  "dimensions": {
    "user_country": {
      "id": "user_country",
      "name": "国家",
      "column": "users.country",
      "description": "用户所属国家",
      "entityId": "users"
    },
    "product_category": {
      "id": "product_category",
      "name": "产品类别",
      "column": "products.category",
      "description": "产品所属分类",
      "entityId": "products"
    },
    "order_date": {
      "id": "order_date",
      "name": "下单日期",
      "column": "orders.order_date",
      "description": "下单的时间日期",
      "entityId": "orders"
    },
    "username": {
      "id": "username",
      "name": "用户名",
      "column": "users.username",
      "description": "用户名称",
      "entityId": "users"
    }
  },
  "relationships": [
    {
      "fromEntityId": "users",
      "toEntityId": "orders",
      "joinOn": "users.id = orders.user_id",
      "type": "one_to_many"
    },
    {
      "fromEntityId": "products",
      "toEntityId": "orders",
      "joinOn": "products.id = orders.product_id",
      "type": "one_to_many"
    },
    {
      "fromEntityId": "users",
      "toEntityId": "returns",
      "joinOn": "users.id = returns.user_id",
      "type": "one_to_many"
    }

  ]
}
